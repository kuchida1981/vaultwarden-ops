# This file documents the variables docker-compose.yml expects.
# In production, /opt/vaultwarden/.env is generated automatically by the
# VM's startup-script (see terraform/main/templates/startup-script.sh.tftpl),
# which pulls ADMIN_TOKEN from Google Secret Manager. This example is for
# local reference only - do not put real secrets in this file.

DOMAIN=https://vaultwarden.u-rei.com
ADMIN_TOKEN=changeme
DATA_DIR=./data
